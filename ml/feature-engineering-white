// ==============================
// RAW vs LOG SCATTER
// ==============================
function drawScatters() {
  ['raw-scatter','log-scatter'].forEach(id=>{
    const d = clearCanvas(id);
    if(!d) return;
    const {ctx,W,H}=d;
    const r = rng(42);
    const px=40,py=20,bw=W-px-10,bh=H-py-30;
    ctx.fillStyle='#f8f9fd'; ctx.fillRect(0,0,W,H);
    ctx.strokeStyle=C.border; ctx.lineWidth=1;
    ctx.strokeRect(px,py,bw,bh);
    // axes
    ctx.fillStyle=C.muted; ctx.font=`10px 'IBM Plex Mono'`;
    // generate data
    const N=80;
    const areas=[], prices=[];
    for(let i=0;i<N;i++){
      const a=r()*200+50;
      const p=Math.exp(0.015*a+r()*0.8+5);
      areas.push(a); prices.push(p);
    }
    const maxA=Math.max(...areas), maxP=Math.max(...prices);
    const minP=Math.min(...prices);
    const useLog = id==='log-scatter';
    const yVals = useLog ? prices.map(p=>Math.log(p)) : prices;
    const minY=Math.min(...yVals), maxY=Math.max(...yVals);
    // grid
    ctx.strokeStyle='#d4d8ee'; ctx.lineWidth=0.5;
    for(let i=1;i<5;i++){
      const y=py+bh*i/5;
      ctx.beginPath(); ctx.moveTo(px,y); ctx.lineTo(px+bw,y); ctx.stroke();
    }
    // regression line
    const xm=areas.reduce((a,b)=>a+b)/N;
    const ym=yVals.reduce((a,b)=>a+b)/N;
    let num=0,den=0;
    for(let i=0;i<N;i++){num+=(areas[i]-xm)*(yVals[i]-ym);den+=(areas[i]-xm)**2;}
    const m=num/den, b2=ym-m*xm;
    const x1=Math.min(...areas), x2=Math.max(...areas);
    const sx=v=>px+bw*(v-0)/(maxA);
    const sy=v=>py+bh*(1-(v-minY)/(maxY-minY));
    ctx.strokeStyle=useLog?C.g1:'#b0b4cc'; ctx.lineWidth=2;
    ctx.beginPath(); ctx.moveTo(sx(x1),sy(m*x1+b2)); ctx.lineTo(sx(x2),sy(m*x2+b2)); ctx.stroke();
    // dots
    for(let i=0;i<N;i++){
      ctx.beginPath();
      ctx.arc(sx(areas[i]),sy(yVals[i]),3,0,Math.PI*2);
      ctx.fillStyle=useLog?C.g1+'90':C.g5+'70';
      ctx.fill();
    }
    // labels
    ctx.fillStyle=C.muted; ctx.font=`9px 'IBM Plex Mono'`;
    ctx.fillText('Área (m²)',px+bw/2-20,H-6);
    const ylabel=useLog?'log(Precio)':'Precio';
    ctx.save(); ctx.translate(12,py+bh/2); ctx.rotate(-Math.PI/2);
    ctx.fillText(ylabel,-20,0); ctx.restore();
  });
}

// ==============================
// DISTRIBUTION DEMO
// ==============================
let currentDist='exponential';
function setDist(d,btn){
  currentDist=d;
  document.querySelectorAll('#log-t2 .ctrl-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  drawDistributions();
}

function generateDist(type, N=300) {
  const r=rng(123);
  const data=[];
  if(type==='exponential'){for(let i=0;i<N;i++) data.push(-Math.log(1-r())*2);}
  else if(type==='lognormal'){for(let i=0;i<N;i++){let u=0;for(let j=0;j<6;j++)u+=r();data.push(Math.exp((u-3)*0.8));}}
  else if(type==='pareto'){for(let i=0;i<N;i++) data.push(Math.pow(r()+0.001,-1/1.5));}
  return data;
}

function drawHistogram(canvasId, data, color, label) {
  const d = clearCanvas(canvasId); if(!d) return;
  const {ctx,W,H}=d;
  ctx.fillStyle='#f8f9fd'; ctx.fillRect(0,0,W,H);
  const bins=25;
  const min=Math.min(...data), max=Math.max(...data)*0.95;
  const binW=(max-min)/bins;
  const counts=new Array(bins).fill(0);
  data.forEach(v=>{if(v<=max){const i=Math.min(Math.floor((v-min)/binW),bins-1);counts[i]++;}});
  const maxC=Math.max(...counts);
  const px=30,py=10,bw=W-px-10,bh=H-py-25;
  // bars
  counts.forEach((c,i)=>{
    const x=px+i*(bw/bins);
    const bh2=bh*(c/maxC);
    const alpha=0.7;
    ctx.fillStyle=color+'b0';
    ctx.fillRect(x,py+bh-bh2,bw/bins-1,bh2);
    ctx.strokeStyle=color; ctx.lineWidth=0.5;
    ctx.strokeRect(x,py+bh-bh2,bw/bins-1,bh2);
  });
  // axis
  ctx.strokeStyle=C.border; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(px,py); ctx.lineTo(px,py+bh); ctx.lineTo(px+bw,py+bh); ctx.stroke();
  // skewness
  const mean=data.reduce((a,b)=>a+b)/data.length;
  const std=Math.sqrt(data.map(x=>(x-mean)**2).reduce((a,b)=>a+b)/data.length);
  const skew=data.map(x=>((x-mean)/std)**3).reduce((a,b)=>a+b)/data.length;
  return skew;
}

function drawDistributions() {
  const raw=generateDist(currentDist);
  const logged=raw.map(x=>Math.log1p(x));
  const s1=drawHistogram('dist-before',raw,C.g3,'original');
  const s2=drawHistogram('dist-after',logged,C.g1,'log');
  // skew bars
  function skewHtml(skew, color) {
    const abs=Math.min(Math.abs(skew),3);
    const pct=abs/3*100;
    const label=Math.abs(skew)<0.5?'Simétrica':skew>0?'Sesgo positivo ↗':'Sesgo negativo ↙';
    return `<span style="font-size:10px;color:${C.muted};font-family:'IBM Plex Mono';width:120px;flex-shrink:0">skewness: <span style="color:${color}">${skew?.toFixed(2)}</span></span>
      <div style="flex:1;height:6px;background:${C.surface};border-radius:3px;overflow:hidden;">
        <div style="height:100%;width:${pct}%;background:${color};border-radius:3px;"></div>
      </div>
      <span style="font-size:10px;color:${color};font-family:'IBM Plex Mono';width:100px;flex-shrink:0">${label}</span>`;
  }
  document.getElementById('skew-before').innerHTML=skewHtml(s1,C.g3);
  document.getElementById('skew-after').innerHTML=skewHtml(s2,C.g1);
  const insights={
    exponential:'La distribución exponencial es clásica en tiempos de espera, llamadas de soporte, tiempo hasta fallo. Después de log1p(), la distribución se acerca a la normalidad → los modelos lineales y las redes neuronales funcionan mucho mejor.',
    lognormal:'La distribución log-normal aparece naturalmente en precios de activos, salarios, tamaño de empresas. El log la convierte en normal → la regresión lineal puede capturar relaciones lineales en el espacio log.',
    pareto:'La distribución de Pareto (ley de potencias) aparece en distribución de riqueza, tráfico web, seguidores en redes. Cola extremadamente larga. La transformación log comprime drasticamente los valores extremos.'
  };
  document.getElementById('dist-insight').innerHTML=`<strong>Insight:</strong> ${insights[currentDist]}`;
}

// ==============================
// BINNING DEMO
// ==============================
let binType='width';
function setBinType(t,btn){
  binType=t;
  document.querySelectorAll('#bin-t2 .ctrl-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  drawBinDemo();
}
function updateBinDemo(){
  const v=document.getElementById('bin-slider').value;
  document.getElementById('bin-val').textContent=v;
  drawBinDemo();
}

function drawBinDemo() {
  const d=clearCanvas('bin-canvas'); if(!d) return;
  const {ctx,W,H}=d;
  ctx.fillStyle='#f8f9fd'; ctx.fillRect(0,0,W,H);
  const nBins=parseInt(document.getElementById('bin-slider')?.value||5);
  const r=rng(77);
  const N=400;
  const data=[];
  for(let i=0;i<N;i++){
    let u=0; for(let j=0;j<4;j++) u+=r();
    data.push(u*30+20+(r()>0.8?r()*60:0));
  }
  const min=Math.min(...data), max=Math.max(...data);
  let edges=[];
  if(binType==='width'){
    for(let i=0;i<=nBins;i++) edges.push(min+(max-min)*i/nBins);
  } else {
    const sorted=[...data].sort((a,b)=>a-b);
    for(let i=0;i<=nBins;i++) edges.push(sorted[Math.floor(i*(N-1)/nBins)]);
  }
  const counts=new Array(nBins).fill(0);
  data.forEach(v=>{
    for(let i=0;i<nBins;i++){
      if(v>=edges[i]&&v<edges[i+1]){counts[i]++;break;}
      if(i===nBins-1&&v>=edges[i]) counts[i]++;
    }
  });
  const maxC=Math.max(...counts);
  const px=35,py=15,bw=W-px-15,bh=H-py-35;
  const colors=[C.g1,C.g2,C.g3,C.g4,C.g5,C.g6,'#c084fc','#34d399','#f87171','#fbbf24',
    C.g1,C.g2,C.g3,C.g4,C.g5,C.g6,'#c084fc','#34d399','#f87171','#fbbf24'];
  counts.forEach((c,i)=>{
    const x=px+bw*i/nBins;
    const bh2=bh*(c/maxC);
    ctx.fillStyle=colors[i%colors.length]+'99';
    ctx.fillRect(x+1,py+bh-bh2,bw/nBins-2,bh2);
    ctx.strokeStyle=colors[i%colors.length]; ctx.lineWidth=1;
    ctx.strokeRect(x+1,py+bh-bh2,bw/nBins-2,bh2);
    // edge label
    if(i<4||i===nBins-1){
      ctx.fillStyle=C.muted; ctx.font=`9px 'IBM Plex Mono'`;
      ctx.fillText(edges[i].toFixed(0),x,py+bh+15);
    }
  });
  ctx.strokeStyle=C.border; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(px,py); ctx.lineTo(px,py+bh); ctx.lineTo(px+bw,py+bh); ctx.stroke();
  const tips={
    2:'Con solo 2 bins pierdes demasiada información. Los modelos lineales no podrán distinguir matices dentro de cada grupo.',
    3:'3-4 bins: útil para capturar rangos cualitativos con significado (bajo/medio/alto). Simple e interpretable.',
    5:'5-7 bins: balance común en práctica. Captura la forma general de la distribución sin fragmentar demasiado.',
    10:'8-12 bins: mayor detalle, pero puede introducir ruido en muestras pequeñas. Bueno con >1000 observaciones.',
    15:'Con muchos bins la discretización pierde utilidad. Considera features continuas o polynomial features.',
  };
  let tipKey=nBins<=2?2:nBins<=4?3:nBins<=7?5:nBins<=12?10:15;
  document.getElementById('bin-insight').innerHTML=`<strong>N=${nBins} bins (${binType==='width'?'Equal-Width':'Equal-Frequency'}):</strong> ${tips[tipKey]}`;
}

// ==============================
// POLYNOMIAL DEMO
// ==============================
let polyDeg=1;
function setPolyDeg(d,btn){
  polyDeg=d;
  document.querySelectorAll('#poly-t2 .ctrl-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  drawPolyDemo();
}

function drawPolyDemo(){
  const d=clearCanvas('poly-canvas'); if(!d) return;
  const {ctx,W,H}=d;
  ctx.fillStyle='#f8f9fd'; ctx.fillRect(0,0,W,H);
  const r=rng(55);
  const N=60;
  const xs=[],ys=[];
  for(let i=0;i<N;i++){
    const x=r()*10-5;
    const y=0.3*x*x-0.2*x+1+r()*2-1;
    xs.push(x); ys.push(y);
  }
  const px=35,py=15,bw=W-px-15,bh=H-py-30;
  const minX=Math.min(...xs),maxX=Math.max(...xs);
  const minY=Math.min(...ys)-1,maxY=Math.max(...ys)+1;
  const sx=v=>px+bw*(v-minX)/(maxX-minX);
  const sy=v=>py+bh*(1-(v-minY)/(maxY-minY));
  // grid
  ctx.strokeStyle='#d4d8ee'; ctx.lineWidth=0.5;
  for(let i=1;i<5;i++){ctx.beginPath();ctx.moveTo(px,py+bh*i/5);ctx.lineTo(px+bw,py+bh*i/5);ctx.stroke();}
  // dots
  for(let i=0;i<N;i++){
    ctx.beginPath(); ctx.arc(sx(xs[i]),sy(ys[i]),4,0,Math.PI*2);
    ctx.fillStyle=C.g5+'90'; ctx.fill();
  }
  // fit polynomial
  function polyFit(xs,ys,deg){
    const n=xs.length;
    const A=[]; const b=[];
    for(let i=0;i<n;i++){
      const row=[]; for(let j=0;j<=deg;j++) row.push(Math.pow(xs[i],j));
      A.push(row); b.push(ys[i]);
    }
    // normal equations: (A'A)c = A'b  — simple for deg<=3
    function matMul(A,B){const r=A.length,c=B[0].length,k=B.length;const C=Array.from({length:r},()=>new Array(c).fill(0));for(let i=0;i<r;i++)for(let j=0;j<c;j++)for(let l=0;l<k;l++)C[i][j]+=A[i][l]*B[l][j];return C;}
    function transpose(M){return M[0].map((_,i)=>M.map(r=>r[i]));}
    const At=transpose(A);
    const AtA=matMul(At,A);
    const Atb=matMul(At,b.map(v=>[v])).map(r=>r[0]);
    // Gaussian elimination
    const m=AtA.length;
    for(let col=0;col<m;col++){
      let maxR=col;
      for(let row=col+1;row<m;row++) if(Math.abs(AtA[row][col])>Math.abs(AtA[maxR][col])) maxR=row;
      [AtA[col],AtA[maxR]]=[AtA[maxR],AtA[col]]; [Atb[col],Atb[maxR]]=[Atb[maxR],Atb[col]];
      for(let row=col+1;row<m;row++){
        const f=AtA[row][col]/AtA[col][col];
        for(let k=col;k<m;k++) AtA[row][k]-=f*AtA[col][k];
        Atb[row]-=f*Atb[col];
      }
    }
    const c=new Array(m).fill(0);
    for(let i=m-1;i>=0;i--){c[i]=Atb[i];for(let j=i+1;j<m;j++)c[i]-=AtA[i][j]*c[j];c[i]/=AtA[i][i];}
    return c;
  }
  const coeffs=polyFit(xs,ys,polyDeg);
  const colors=[C.g5,C.g4,C.g1];
  ctx.strokeStyle=colors[polyDeg-1]; ctx.lineWidth=2.5;
  ctx.beginPath();
  for(let i=0;i<=200;i++){
    const xv=minX+(maxX-minX)*i/200;
    let yv=0; for(let j=0;j<=polyDeg;j++) yv+=coeffs[j]*Math.pow(xv,j);
    if(yv<minY||yv>maxY) continue;
    if(i===0) ctx.moveTo(sx(xv),sy(yv)); else ctx.lineTo(sx(xv),sy(yv));
  }
  ctx.stroke();
  // R²
  const ymean=ys.reduce((a,b)=>a+b)/N;
  let ss_res=0,ss_tot=0;
  for(let i=0;i<N;i++){
    let yhat=0; for(let j=0;j<=polyDeg;j++) yhat+=coeffs[j]*Math.pow(xs[i],j);
    ss_res+=(ys[i]-yhat)**2; ss_tot+=(ys[i]-ymean)**2;
  }
  const r2=1-ss_res/ss_tot;
  const r2el=document.getElementById('poly-r2');
  if(r2el){
    const descs=['La recta no puede capturar la curvatura real de los datos.','El polinomio de grado 2 captura la parábola subyacente perfectamente.','Grado 3 mejora marginalmente pero ya con riesgo de overfitting.'];
    r2el.innerHTML=`R² = ${r2.toFixed(3)} — ${descs[polyDeg-1]}`;
  }
  ctx.strokeStyle=C.border; ctx.lineWidth=1;
  ctx.beginPath();ctx.moveTo(px,py);ctx.lineTo(px,py+bh);ctx.lineTo(px+bw,py+bh);ctx.stroke();
}

