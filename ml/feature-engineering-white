let scalerView='none';
function setScalerView(v,btn){
  scalerView=v;
  document.querySelectorAll('#sc-t2 .ctrl-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  drawScalerDemo();
}

function drawScalerDemo(){
  const d=clearCanvas('scaler-canvas'); if(!d) return;
  const {ctx,W,H}=d;
  ctx.fillStyle='#f8f9fd'; ctx.fillRect(0,0,W,H);
  const r=rng(33);
  const N=120;
  const raw=[];
  for(let i=0;i<N;i++){
    let v=r()*100+20;
    if(r()>0.9) v+=r()*200;
    raw.push(v);
  }
  const mean=raw.reduce((a,b)=>a+b)/N;
  const std=Math.sqrt(raw.map(x=>(x-mean)**2).reduce((a,b)=>a+b)/N);
  const min=Math.min(...raw), max=Math.max(...raw);
  const q1=raw.slice().sort((a,b)=>a-b)[Math.floor(N*0.25)];
  const q2=raw.slice().sort((a,b)=>a-b)[Math.floor(N*0.5)];
  const q3=raw.slice().sort((a,b)=>a-b)[Math.floor(N*0.75)];
  let data;
  if(scalerView==='none') data=raw;
  else if(scalerView==='standard') data=raw.map(v=>(v-mean)/std);
  else if(scalerView==='minmax') data=raw.map(v=>(v-min)/(max-min));
  else data=raw.map(v=>(v-q2)/(q3-q1));
  const bins=30;
  const dmin=Math.min(...data), dmax=Math.max(...data)*0.99;
  const binW=(dmax-dmin)/bins;
  const counts=new Array(bins).fill(0);
  data.forEach(v=>{if(v<=dmax){const i=Math.min(Math.floor((v-dmin)/binW),bins-1);counts[i]++;}});
  const maxC=Math.max(...counts);
  const px=35,py=15,bw=W-px-15,bh=H-py-30;
  const colors={none:C.g3,standard:C.g1,minmax:C.g5,robust:C.g4};
  counts.forEach((c,i)=>{
    const x=px+i*(bw/bins);
    const bh2=bh*(c/maxC);
    ctx.fillStyle=colors[scalerView]+'80'; ctx.strokeStyle=colors[scalerView]; ctx.lineWidth=0.5;
    ctx.fillRect(x,py+bh-bh2,bw/bins-1,bh2);
  });
  // outlier mark
  if(scalerView==='none'){
    const outX=px+bw*0.9;
    ctx.strokeStyle=C.danger; ctx.lineWidth=2; ctx.setLineDash([4,3]);
    ctx.beginPath(); ctx.moveTo(outX,py); ctx.lineTo(outX,py+bh); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle=C.danger; ctx.font=`10px 'IBM Plex Mono'`; ctx.textAlign='center';
    ctx.fillText('outliers →',outX,py+12);
  }
  ctx.strokeStyle=C.border; ctx.lineWidth=1;
  ctx.beginPath();ctx.moveTo(px,py);ctx.lineTo(px,py+bh);ctx.lineTo(px+bw,py+bh);ctx.stroke();
  ctx.fillStyle=C.muted; ctx.font=`9px 'IBM Plex Mono'`; ctx.textAlign='center';
  ctx.fillText(dmin.toFixed(2),px+10,H-10);
  ctx.fillText(dmax.toFixed(2),px+bw-10,H-10);
  const insights={
    none:'Datos sin escalar: rango [20, 320]. Los outliers comprime toda la distribución principal. Un modelo KNN o SVM trataría esta variable como mucho más importante que otras de rango [0,1].',
    standard:'StandardScaler: media=0, std=1. Los outliers siguen presentes pero en ±3σ. Ideal para regresión, SVM, PCA, KNN. Los gradientes en NN convergen más rápido.',
    minmax:'MinMaxScaler: rango [0,1]. Los outliers extremos comprimen todos los demás valores en una franja estrecha. Solo usar cuando no hay outliers significativos o para imágenes.',
    robust:'RobustScaler usa mediana y IQR en vez de media/std. Los outliers NO distorsionan la escala. La mayoría de datos queda en rango [-2, 2]. Ideal cuando hay outliers importantes.'
  };
  document.getElementById('scaler-insight').innerHTML=`<strong>${scalerView==='none'?'Sin escalado':scalerView}:</strong> ${insights[scalerView]}`;
}

