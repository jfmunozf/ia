  const insights={
    clean:'Modelo sin leakage: Las métricas de train (82%), validación (79%) y producción (78%) son consistentes. Hay una pequeña caída natural por generalización, pero el modelo es confiable.',
    leaky:'Modelo con leakage: Train 99%, Validación 97% — ¡métricas casi perfectas! El equipo está emocionado. PERO en producción solo alcanza 61%. ¡6 semanas de trabajo desperdiciadas!',
    production:'Esta es la realidad al deployar: el modelo que parecía perfecto (97% en val) colapsa a 61% en producción porque la información filtrada ya no existe. El modelo aprendió a "hacer trampa", no a predecir.'
  };
  document.getElementById('leakage-insight').innerHTML=`<strong>${leakageView==='production'?'⚠ Alerta':'Escenario'}:</strong> ${insights[leakageView]}`;
}

// ==============================
// INIT
// ==============================
function initAllCharts(){
  const visible=document.querySelector('.section.visible')?.id;
  if(visible==='sec-overview'){
    drawImpactBars();
    const m=document.getElementById('mod-why');
    if(m&&m.classList.contains('open')){drawScatters();}
    // auto-open first module
  }
  if(visible==='sec-numerical'){
    if(document.getElementById('mod-log')?.classList.contains('open')){
      if(document.getElementById('log-t2')?.classList.contains('active')) drawDistributions();
      if(document.getElementById('log-t2') && document.querySelector('#log-t2.active')) drawDistributions();
    }
    if(document.getElementById('mod-bin')?.classList.contains('open')){
      if(document.getElementById('bin-t2')?.classList.contains('active')) drawBinDemo();
    }
    if(document.getElementById('mod-poly')?.classList.contains('open')){
      if(document.getElementById('poly-t2')?.classList.contains('active')) drawPolyDemo();
    }
  }
  if(visible==='sec-categorical'){
    if(document.getElementById('mod-enc')?.classList.contains('open')){
      if(document.getElementById('enc-t3')?.classList.contains('active')) drawEncoding();
    }
  }
  if(visible==='sec-temporal'){
    if(document.getElementById('mod-time')?.classList.contains('open')){
      if(document.getElementById('time-t2')?.classList.contains('active')) drawCyclic();
      if(document.getElementById('time-t3')?.classList.contains('active')) drawLagDemo();
    }
  }
  if(visible==='sec-selection'){
    if(document.getElementById('mod-sel')?.classList.contains('open')){
      if(document.getElementById('sel-t2')?.classList.contains('active')) drawImportance();
    }
  }
  if(visible==='sec-scaling'){
    if(document.getElementById('mod-scale')?.classList.contains('open')){
      if(document.getElementById('sc-t2')?.classList.contains('active')) drawScalerDemo();
    }
  }
  if(visible==='sec-leakage'){
    if(document.getElementById('mod-leak')?.classList.contains('open')){
      if(document.getElementById('lk-t3')?.classList.contains('active')) drawLeakageDemo();
    }
  }
}

// Auto-draw on tab/panel switch
document.addEventListener('click', e=>{
  if(e.target.classList.contains('mtab')){
    setTimeout(()=>{
      const panel=e.target.closest('.module-body')?.querySelector('.mpanel.active');
      if(!panel) return;
      const id=panel.id;
      if(id==='log-t2') drawDistributions();
      if(id==='bin-t2') drawBinDemo();
      if(id==='poly-t2') drawPolyDemo();
      if(id==='enc-t3') drawEncoding();
      if(id==='time-t2') drawCyclic();
      if(id==='time-t3') drawLagDemo();
      if(id==='sel-t2') {if(!importanceData) regenerateImportance(); else drawImportance();}
      if(id==='sc-t2') drawScalerDemo();
      if(id==='lk-t3') drawLeakageDemo();
      if(id==='why-t2') drawScatters();
    },60);
  }
});

// Init on load
window.addEventListener('load', ()=>{
  // open first module
  document.querySelector('#sec-overview .module')?.classList.add('open');
  setTimeout(()=>{
    drawImpactBars();
    drawScatters();
  },200);
});

window.addEventListener('resize', ()=>setTimeout(()=>initAllCharts(),100));
</script>
</body>
