function drawLagDemo(){
  const d=clearCanvas('lag-canvas'); if(!d) return;
  const {ctx,W,H}=d;
  ctx.fillStyle='#f8f9fd'; ctx.fillRect(0,0,W,H);
  const r=rng(99);
  const N=60;
  const raw=[];
  let v=100;
  for(let i=0;i<N;i++){v+=r()*12-6+Math.sin(i/7)*5; raw.push(Math.max(0,v));}
  const lag7=raw.map((_,i)=>i>=7?raw[i-7]:null);
  const roll7=raw.map((_,i)=>{if(i<6)return null;let s=0;for(let j=i-6;j<=i;j++)s+=raw[j];return s/7;});
  const px=30,py=15,bw=W-px-15,bh=H-py-20;
  const minY=Math.min(...raw)*0.95, maxY=Math.max(...raw)*1.05;
  const sx=i=>px+bw*i/(N-1);
  const sy=v=>py+bh*(1-(v-minY)/(maxY-minY));
  function drawLine(data, color, dash=[], lw=1.5, alpha=1){
    ctx.strokeStyle=color; ctx.lineWidth=lw;
    ctx.setLineDash(dash); ctx.globalAlpha=alpha;
    ctx.beginPath();
    let first=true;
    data.forEach((v,i)=>{
      if(v===null) return;
      if(first){ctx.moveTo(sx(i),sy(v));first=false;} else ctx.lineTo(sx(i),sy(v));
    });
    ctx.stroke(); ctx.setLineDash([]); ctx.globalAlpha=1;
  }
  // grid
  ctx.strokeStyle='#d4d8ee'; ctx.lineWidth=0.5;
  for(let i=1;i<4;i++){ctx.beginPath();ctx.moveTo(px,py+bh*i/4);ctx.lineTo(px+bw,py+bh*i/4);ctx.stroke();}
  if(lagView==='raw'||lagView==='all') drawLine(raw,C.g5,[], 2);
  if(lagView==='lag'||lagView==='all') drawLine(lag7,C.g3,[5,3], 1.8, lagView==='lag'?1:0.7);
  if(lagView==='rolling'||lagView==='all') drawLine(roll7,C.g1,[], lagView==='rolling'?2.5:1.8, lagView==='rolling'?1:0.8);
  ctx.strokeStyle=C.border; ctx.lineWidth=1;
  ctx.beginPath();ctx.moveTo(px,py);ctx.lineTo(px,py+bh);ctx.lineTo(px+bw,py+bh);ctx.stroke();
  // legend
  const legend=[];
  if(lagView==='raw'||lagView==='all') legend.push({c:C.g5,l:'Original'});
  if(lagView==='lag'||lagView==='all') legend.push({c:C.g3,l:'Lag-7 (hace 7 días)'});
  if(lagView==='rolling'||lagView==='all') legend.push({c:C.g1,l:'Rolling Mean 7d'});
  legend.forEach((l,i)=>{
    ctx.fillStyle=l.c; ctx.fillRect(px+i*140,py-2,12,3);
    ctx.fillStyle=C.muted; ctx.font=`9px 'IBM Plex Mono'`; ctx.textAlign='left';
    ctx.fillText(l.l,px+i*140+16,py+2);
  });
  const insights={
    raw:'La serie original captura la dinámica de ventas diarias. Por sí sola, es difícil que un modelo prediga el próximo valor sin contexto temporal.',
    lag:'Lag-7 desplaza la serie 7 días atrás. Ahora el modelo puede "ver" las ventas de la semana pasada para predecir hoy. Captura autocorrelación y patrones semanales.',
    rolling:'El rolling mean de 7 días suaviza el ruido y expone la tendencia local. El modelo puede aprender si las ventas están subiendo o bajando en promedio.',
    all:'Combinando las 3 líneas: la señal original, su lag para detectar patrones históricos, y el rolling mean para la tendencia → el modelo tiene mucha más información para predecir.'
  };
  document.getElementById('lag-insight').innerHTML=`<strong>${lagView==='all'?'Vista completa':'Insight'}:</strong> ${insights[lagView]}`;
}

