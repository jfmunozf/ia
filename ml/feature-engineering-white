function getCtx(id) {
  const c = document.getElementById(id);
  if(!c) return null;
  const r = c.getBoundingClientRect();
  if(r.width === 0) return null;
  c.width = r.width * window.devicePixelRatio || c.offsetWidth * 2;
  c.height = c.height * window.devicePixelRatio || c.height * 2;
  const ctx = c.getContext('2d');
  ctx.scale(window.devicePixelRatio || 1, window.devicePixelRatio || 1);
  c._w = r.width || c.offsetWidth;
  c._h = c.getBoundingClientRect().height || 180;
  return ctx;
}

function clearCanvas(id) {
  const c = document.getElementById(id);
  if(!c) return null;
  const W = c.offsetWidth; const H = c.offsetHeight || 180;
  c.width = W; c.height = H;
  const ctx = c.getContext('2d');
  ctx.clearRect(0,0,W,H);
  return {ctx,W,H};
}

const C = {
  g1:'#0fa37a', g2:'#5b4fcf', g3:'#d4700a', g4:'#c4317a',
  g5:'#0b8fc4', g6:'#5a8a00', danger:'#d93030', warn:'#b07800',
  bg:'#f0f2f8', surface:'#f5f6fb', border:'#d4d8ee', muted:'#6b6f94', text:'#1a1c2e'
};

function rng(seed){let s=seed;return()=>{s=(s*16807+0)%2147483647;return(s-1)/2147483646};}

