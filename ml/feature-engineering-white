function drawEncoding(){
  const d=clearCanvas('enc-canvas'); if(!d) return;
  const {ctx,W,H}=d;
  ctx.fillStyle='#f8f9fd'; ctx.fillRect(0,0,W,H);
  const cities=['Bogotá','Medellín','Cali','Barranquilla','Cartagena'];
  const counts=[120,90,65,45,30];
  const targets=[450,380,290,200,340];
  const total=counts.reduce((a,b)=>a+b);
  const rowH=36, startY=20, px=140;
  const bw=W-px-20;
  const encodings={
    ohe:{label:'One-Hot Encoding',fn:(i)=>cities.map((_,j)=>j===i?1:0),render:(vals,i,y)=>{
      vals.forEach((v,j)=>{
        const x=px+j*(bw/5)+2;
        ctx.fillStyle=v===1?C.g2+'c0':'#eceef6';
        ctx.strokeStyle=v===1?C.g2:C.border;
        ctx.lineWidth=1;
        const w=bw/5-4; const bh=rowH-8;
        ctx.beginPath(); ctx.roundRect(x,y,w,bh,3); ctx.fill(); ctx.stroke();
        ctx.fillStyle=v===1?'#fff':C.muted; ctx.font=`bold 11px 'IBM Plex Mono'`;
        ctx.textAlign='center'; ctx.fillText(v,x+w/2,y+bh/2+4);
      });
    }},
    label:{label:'Label Encoding',fn:(i)=>[i],render:(vals,i,y)=>{
      const x=px+2; const w=60; const bh=rowH-8;
      ctx.fillStyle=C.g3+'90'; ctx.strokeStyle=C.g3; ctx.lineWidth=1;
      ctx.beginPath(); ctx.roundRect(x,y,w,bh,3); ctx.fill(); ctx.stroke();
      ctx.fillStyle='#fff'; ctx.font=`bold 14px 'IBM Plex Mono'`;
      ctx.textAlign='center'; ctx.fillText(vals[0],x+w/2,y+bh/2+5);
    }},
    target:{label:'Target Encoding (media del target)',fn:(i)=>[targets[i]],render:(vals,i,y)=>{
      const x=px+2; const bh=rowH-8;
      const norm=vals[0]/Math.max(...targets);
      const w=Math.max((bw-4)*norm,4);
      ctx.fillStyle=C.g4+'80'; ctx.strokeStyle=C.g4; ctx.lineWidth=1;
      ctx.beginPath(); ctx.roundRect(x,y,w,bh,3); ctx.fill(); ctx.stroke();
      ctx.fillStyle=C.text; ctx.font=`11px 'IBM Plex Mono'`;
      ctx.textAlign='left'; ctx.fillText(`$${vals[0]}K`,x+w+6,y+bh/2+4);
    }},
    freq:{label:'Frequency Encoding',fn:(i)=>[counts[i]/total],render:(vals,i,y)=>{
      const x=px+2; const bh=rowH-8;
      const w=Math.max((bw-4)*vals[0],4);
      ctx.fillStyle=C.g5+'80'; ctx.strokeStyle=C.g5; ctx.lineWidth=1;
      ctx.beginPath(); ctx.roundRect(x,y,w,bh,3); ctx.fill(); ctx.stroke();
      ctx.fillStyle=C.text; ctx.font=`11px 'IBM Plex Mono'`;
      ctx.textAlign='left'; ctx.fillText(`${(vals[0]*100).toFixed(1)}%`,x+w+6,y+bh/2+4);
    }},
  };
  const enc=encodings[encView];
  // header
  ctx.fillStyle=C.muted; ctx.font=`bold 10px 'IBM Plex Mono'`; ctx.textAlign='left';
  ctx.fillText(enc.label,px,14);
  if(encView==='ohe'){
    cities.forEach((c,j)=>{
      ctx.fillStyle=C.muted; ctx.font=`9px 'IBM Plex Mono'`; ctx.textAlign='center';
      ctx.fillText(c.substring(0,3),px+j*(bw/5)+bw/10,startY+8);
    });
  }
  cities.forEach((city,i)=>{
    const y=startY+20+i*rowH;
    ctx.fillStyle=C.text; ctx.font=`12px 'Outfit'`; ctx.textAlign='right';
    ctx.fillText(city,px-10,y+rowH/2);
    enc.render(enc.fn(i),i,y);
  });
  const insights={
    ohe:'One-Hot crea 5 columnas binarias (una por ciudad). El modelo lineal puede asignar un coeficiente independiente a cada ciudad. Ninguna ciudad es "mayor" que otra.',
    label:'Label Encoding asigna 0→Bogotá, 1→Medellín, ..., 4→Cartagena. Un modelo lineal interpretará Cartagena como "4x mayor" que Bogotá — ¡error conceptual! Solo usar con árboles.',
    target:'Target Encoding reemplaza cada ciudad por la media del target (ej: precio promedio de arriendo). Muy informativo pero requiere cross-validation para evitar que la propia observación "se vea a sí misma".',
    freq:'Frequency Encoding: Bogotá aparece en 34% de los datos → su valor es 0.34. Simple, sin leakage. Pierde distinción cuando dos ciudades tienen igual frecuencia.'
  };
  document.getElementById('enc-insight').innerHTML=`<strong>¿Qué ves aquí?</strong> ${insights[encView]}`;
}

