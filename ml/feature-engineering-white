<span class="cm"># ── Label Encoding (solo para ordinales o tree-based)</span>
le = LabelEncoder()
df[<span class="st">'nivel_enc'</span>] = le.<span class="fn">fit_transform</span>(df[<span class="st">'nivel'</span>])

<span class="cm"># ── Target Encoding CON cross-validation para evitar leakage</span>
