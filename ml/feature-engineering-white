function drawCyclic(){
  const d=clearCanvas('cyclic-canvas'); if(!d) return;
  const {ctx,W,H}=d;
  ctx.fillStyle='#f8f9fd'; ctx.fillRect(0,0,W,H);
  const months=['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  if(cyclicView==='raw'){
    const px=35,py=20,bw=W-px-20,bh=H-py-30;
    const barW=bw/12-4;
    months.forEach((m,i)=>{
      const x=px+i*(bw/12)+2;
      ctx.fillStyle=C.g3+'90'; ctx.strokeStyle=C.g3; ctx.lineWidth=1;
      const bh2=bh*(i+1)/12;
      ctx.fillRect(x,py+bh-bh2,barW,bh2);
      ctx.fillStyle=C.muted; ctx.font=`9px 'IBM Plex Mono'`; ctx.textAlign='center';
      ctx.fillText(m,x+barW/2,H-8);
      ctx.fillStyle=C.text; ctx.font=`bold 10px 'IBM Plex Mono'`;
      ctx.fillText(i+1,x+barW/2,py+bh-bh2-4);
    });
    ctx.strokeStyle=C.border; ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(px,py);ctx.lineTo(px,py+bh);ctx.lineTo(px+bw,py+bh);ctx.stroke();
    ctx.fillStyle=C.danger+'99'; ctx.font=`11px 'IBM Plex Mono'`;
    ctx.textAlign='center';
    ctx.fillText('PROBLEMA: distancia(Dic=12, Ene=1) = 11 — ¡Pero son adyacentes!',W/2,H-2);
    document.getElementById('cyclic-insight').innerHTML='<strong>Problema:</strong> Para el modelo, Diciembre (12) y Enero (1) están a 11 unidades. Febrero (2) está más cerca de Enero que Diciembre. Pero en realidad Dic y Ene están a 1 mes de distancia.';
  } else {
    // sin/cos
    const cx=W/2, cy=H/2, rad=Math.min(W,H)*0.38;
    ctx.strokeStyle=C.border; ctx.lineWidth=1;
    ctx.beginPath(); ctx.arc(cx,cy,rad,0,Math.PI*2); ctx.stroke();
    months.forEach((m,i)=>{
      const angle=(i/12)*Math.PI*2 - Math.PI/2;
      const x=cx+Math.cos(angle)*rad;
      const y=cy+Math.sin(angle)*rad;
      ctx.beginPath(); ctx.arc(x,y,7,0,Math.PI*2);
      ctx.fillStyle=C.g1+'c0'; ctx.fill();
      ctx.strokeStyle=C.g1; ctx.lineWidth=1.5; ctx.stroke();
      ctx.fillStyle=C.text; ctx.font=`10px 'Outfit'`; ctx.textAlign='center';
      const lx=cx+Math.cos(angle)*(rad+20);
      const ly=cy+Math.sin(angle)*(rad+20)+4;
      ctx.fillText(m,lx,ly);
      ctx.fillStyle=C.muted; ctx.font=`8px 'IBM Plex Mono'`; ctx.textAlign='center';
      ctx.fillText(`${i+1}`,x,y+3);
    });
    // highlight dic-ene distance
    const a1=(11/12)*Math.PI*2-Math.PI/2;
    const a2=(0/12)*Math.PI*2-Math.PI/2;
    ctx.strokeStyle=C.g1; ctx.lineWidth=2; ctx.setLineDash([4,3]);
    ctx.beginPath();
    ctx.moveTo(cx+Math.cos(a1)*rad,cy+Math.sin(a1)*rad);
    ctx.lineTo(cx+Math.cos(a2)*rad,cy+Math.sin(a2)*rad);
    ctx.stroke(); ctx.setLineDash([]);
    ctx.fillStyle=C.g1; ctx.font=`10px 'IBM Plex Mono'`; ctx.textAlign='center';
    ctx.fillText('1 paso ✓',cx,cy-8);
    document.getElementById('cyclic-insight').innerHTML='<strong>Solución sin/cos:</strong> Representar el mes como punto en un círculo. Diciembre y Enero están adyacentes (1 paso). La distancia euclidiana entre cualquier par de meses refleja su proximidad real en el año.';
  }
}

